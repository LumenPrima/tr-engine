# Direct API access (no auth injection — caller provides their own token)
tr-engine.luxprimatech.com {
	reverse_proxy tr-engine:8080
}

# Dashboard frontend + API proxy
# Caddy injects the read token for unauthenticated requests so the web UI
# works without manual token entry. When the browser sends its own
# Authorization header (e.g. write token), Caddy passes it through.
tr-dashboard.luxprimatech.com {
	handle /api/* {
		@no_auth not header Authorization *
		request_header @no_auth Authorization "Bearer {$AUTH_TOKEN}"
		reverse_proxy tr-engine:8080
	}

	handle {
		reverse_proxy tr-dashboard:80
	}
}
